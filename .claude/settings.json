{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(pnpm run type-check)",
      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run mock)",
      "Bash(pnpm run storybook)",
      "Bash(pnpm lint*)",
      "Bash(pnpm lint --fix*)",
      "Bash(pnpm install*)",
      "Bash(pnpm test:e2e:local)",
      "Bash(pnpm run test:e2e:local)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(gh issue create*)",
      "Bash(gh issue view*)",
      "Bash(gh issue comment*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue list*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)"
    ],
    "deny": [
      "Bash(pnpm run build)",
      "Bash(git push --force*)",
      "Bash(git push origin main)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$CLAUDE_PROJECT_DIR/.claude/logs\" && jq -r '\"\\(now | todate) \\(.tool_name)\"' >> \"$CLAUDE_PROJECT_DIR/.claude/logs/tool-usage.log\" 2>/dev/null || true",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
